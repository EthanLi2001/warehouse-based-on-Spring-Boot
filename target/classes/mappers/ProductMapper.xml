<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.baidu.myshop.dao.ProductMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.baidu.myshop.pojo.Product">
        <id column="pid" property="pid" />
        <result column="pname" property="pname" />
        <result column="price" property="price" />
        <result column="pfile" property="pfile" />
        <result column="description" property="description" />
        <result column="minStock" property="minStock" />
        <result column="maxStock" property="maxStock" />
    </resultMap>

</mapper>
